<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>ru</string>
	</array>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>MadFrog</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<!--
	  UIRequiredDeviceCapabilities — explicit declaration added 2026-05-28
	  after Apple rejected build 89 (1.0.27) under Guideline 2.3:
	  "The UIRequiredDeviceCapabilities key in the Info.plist is set up
	  in such a way that the app will not install on the device used in
	  review" (iPhone 17 Pro Max + iPad Air 11-inch M3, iOS 26.5).
	  Build 89 had no explicit declaration in source — Xcode 26 auto-
	  derived `arm64` (verified locally via `plutil` on the built .app).
	  Restating the same value explicitly in source removes any
	  ambiguity Apple's automated review tool might infer from the
	  auto-derived form.
	-->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSExceptionDomains</key>
		<dict>
			<!-- TD-DE-PRUNE 2026-05-28: 162.19.242.30 (DE/OVH Frankfurt)
			     ATS exception removed — DE retired 2026-05-25 and is no
			     longer in AppConfig.directBackendIPs. -->
			<key>147.45.252.234</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSExceptionRequiresForwardSecrecy</key>
				<false/>
				<key>NSExceptionMinimumTLSVersion</key>
				<string>TLSv1.2</string>
			</dict>
			<key>185.218.0.43</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSExceptionRequiresForwardSecrecy</key>
				<false/>
				<key>NSExceptionMinimumTLSVersion</key>
				<string>TLSv1.2</string>
			</dict>
		</dict>
	</dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.madfrog.vpn.googlesignin</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.111150560265-aao2f3qes3b442f14s3cjg3vl77qu2t8</string>
			</array>
		</dict>
	</array>
	<key>GIDClientID</key>
	<string>111150560265-aao2f3qes3b442f14s3cjg3vl77qu2t8.apps.googleusercontent.com</string>
	<!--
	  SENTRY_DSN — populated at build time (xcconfig / CI secret), NOT committed.
	  Empty string disables crash reporting (CrashReporter.start() is a no-op).
	  See docs/decisions/0007-sentry-eu-crash-reporting.md.
	  Region: EU (de.sentry.io) — GDPR-aligned for a privacy-focused VPN brand.
	-->
	<key>SENTRY_DSN</key>
	<string></string>
</dict>
</plist>
