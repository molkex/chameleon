<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS App Store export options for MadFrogVPNMac.

  signingStyle = automatic (with `xcodebuild -allowProvisioningUpdates` + the
  ASC API key): xcodebuild generates a Mac App Store distribution profile that
  INCLUDES the group.com.madfrog.vpn App Group on the fly. This unblocked CLI
  release on 2026-05-30 (build 91). The old manual profiles ("MadFrog Mac App
  Store 2" / "...Tunnel App Store 2") never carried the App Group, and the ASC
  API has no /v1/appGroups endpoint to add it, so manual export failed with
  "profile doesn't support the group.com.madfrog.vpn App Group". Automatic
  provisioning sidesteps it — no Xcode Organizer UI needed.
-->
<plist version="1.0">
<dict>
	<key>method</key>
	<string>app-store-connect</string>
	<key>destination</key>
	<string>upload</string>
	<key>teamID</key>
	<string>99W3C374T2</string>
	<key>signingStyle</key>
	<string>automatic</string>
	<key>uploadSymbols</key>
	<true/>
	<key>stripSwiftSymbols</key>
	<true/>
	<key>manageAppVersionAndBuildNumber</key>
	<false/>
</dict>
</plist>
