# Chameleon VPN — Backend Configuration
# Copy to .env and fill in your values

# === Required ===
DATABASE_URL=postgresql://chameleon:CHANGE_ME@localhost:5432/chameleon
REDIS_URL=redis://:CHANGE_ME@localhost:6379/0
DB_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

# VPN Reality (generate with: xray x25519)
REALITY_PRIVATE_KEY=
REALITY_PUBLIC_KEY=
REALITY_SNIS=ads.x5.ru

# === JWT Secrets (auto-generated if empty, set for persistence across restarts) ===
ADMIN_SESSION_SECRET=
ADMIN_JWT_SECRET=
MOBILE_JWT_SECRET=

# === Optional: Protocols ===
HY2_PASSWORD=
HY2_OBFS_PASSWORD=
WARP_PRIVATE_KEY=
ANYTLS_PASSWORD=
NAIVE_USERNAME=
NAIVE_PASSWORD=
CDN_DOMAIN=

# === Environment ===
ENVIRONMENT=production
RUST_LOG=info,sqlx=warn
