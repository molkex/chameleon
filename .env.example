# === Marzban VPN Server ===
SUDO_USERNAME=admin
SUDO_PASSWORD=CHANGE_ME
XRAY_JSON=/var/lib/marzban/xray_config.json
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# === Telegram Bot ===
BOT_TOKEN=your-telegram-bot-token-here
# Multiple bots (comma-separated, optional)
BOT_TOKENS=your-telegram-bot-token-here

# === Marzban API (from bot) ===
MARZBAN_HOST=http://localhost:8000
MARZBAN_USERNAME=admin
MARZBAN_PASSWORD=CHANGE_ME

# === Admin Panel ===
ADMIN_IDS=123456789,987654321
ADMIN_SESSION_SECRET=CHANGE_ME_RANDOM_STRING_32_CHARS

# === PostgreSQL ===
POSTGRES_PASSWORD=CHANGE_ME_RANDOM_STRING
DATABASE_URL=postgresql+asyncpg://chameleon:CHANGE_ME_RANDOM_STRING@localhost:5432/chameleon

# === Payment: CryptoBot ===
CRYPTOBOT_TOKEN=123456:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Payment: CryptoCloud ===
CRYPTOCLOUD_TOKEN=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CRYPTOCLOUD_SHOP_ID=CHANGE_ME

# === Payment: FreeKassa (RUB: SBP, Cards, SberPay) ===
# Get from: https://freekassa.net → Settings
FREEKASSA_SHOP_ID=12345
FREEKASSA_API_KEY=your_api_key
FREEKASSA_SECRET1=CHANGE_ME_SECRET_1
FREEKASSA_SECRET2=CHANGE_ME_SECRET_2
# Notification URL (set in FreeKassa dashboard): https://yourdomain.com/api/webhooks/freekassa

# === Multi-Server Deploy ===
# Moscow (Management server)
DEPLOY_PASSWORD_MOSCOW=CHANGE_ME
# Netherlands (Proxy node)
DEPLOY_PASSWORD_NL=CHANGE_ME
# Germany (Proxy node)
DEPLOY_PASSWORD_DE=CHANGE_ME

# Legacy fallback
DEPLOY_HOST=yourdomain.com
DEPLOY_USER=root
DEPLOY_PASSWORD=CHANGE_ME

# === MTProxy ===
MTPROXY_SECRET=CHANGE_ME_HEX_32
MTPROXY_SERVER=1.2.3.4
MTPROXY_PORT=2053
# Multiple servers: server,port,secret,flag,name separated by ;
MTPROXY_SERVERS=147.45.252.234,2053,SECRET_HEX,🇳🇱,Нидерланды;146.19.247.172,2053,SECRET_HEX,🇩🇪,Германия;85.239.49.28,2053,SECRET_HEX,🇷🇺,Москва

# === AmneziaWG (wg-easy API) ===
AWG_PASSWORD=CHANGE_ME_RANDOM_STRING
# Format: name,host,api_port,flag separated by ;
AWG_SERVERS=de,146.19.247.172,51821,🇩🇪;nl,147.45.252.234,51821,🇳🇱

# === Info ===
DASHBOARD_URL=https://1.2.3.4/dashboard

# === Monitor Agent ===
MONITOR_API_KEY=CHANGE_ME_RANDOM_STRING

# === Redis (HA Phase 2 — FSM, throttle, sessions, caches) ===
REDIS_URL=redis://127.0.0.1:6379/0

# === Webhooks (for auto payment confirmation + bot webhook mode) ===
# Public URL of your server (with port if non-standard)
# When set, bot uses webhook mode instead of polling (0 lost messages during restarts)
WEBHOOK_BASE_URL=https://yourdomain.com

# === Cloudflare ===
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_KEY=your_global_api_key
CLOUDFLARE_EMAIL=info@yourdomain.com
# Get from: Cloudflare Dashboard → Select domain → Right sidebar
CLOUDFLARE_ZONE_ID=your_zone_id

# === HA Phase 4-5: NL Standby ===
# Password for PostgreSQL streaming replication user (replicator)
# Required for: deploy_remote.py deploy-standby
PG_REPLICATION_PASSWORD=CHANGE_ME_RANDOM_STRING
# Standby mode flag (set by docker-compose.standby.yml for NL bot)
# When true, disables VPN purchase and shows maintenance message
STANDBY_MODE=false