# ============================================================
# Chameleon VPN — Configuration
# Copy to .env and fill in your values.
# Or use install.sh to auto-generate.
# ============================================================

# === Database ===
DB_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql://chameleon:CHANGE_ME@postgres:5432/chameleon

# === Redis ===
REDIS_PASSWORD=CHANGE_ME
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# === Admin Panel ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

# === JWT Secrets (generate with: openssl rand -hex 32) ===
ADMIN_JWT_SECRET=CHANGE_ME
ADMIN_SESSION_SECRET=CHANGE_ME
MOBILE_JWT_SECRET=CHANGE_ME

# === VPN: Reality Protocol ===
# Generate with: docker run --rm teddysun/xray:1.8.24 xray x25519
REALITY_PRIVATE_KEY=CHANGE_ME
REALITY_PUBLIC_KEY=CHANGE_ME
REALITY_SNIS=ads.x5.ru

# === VPN: Hysteria2 (optional) ===
# HY2_PASSWORD=CHANGE_ME
# HY2_OBFS_PASSWORD=CHANGE_ME
# HY2_SNI=example.com

# === VPN: WARP (optional) ===
# WARP_PRIVATE_KEY=CHANGE_ME
# WARP_ADDRESS_V4=172.16.0.2/32
# WARP_ADDRESS_V6=fd01::/128
# WARP_ENDPOINT=engage.cloudflareclient.com:2408
# WARP_DOMAINS=youtube.com,instagram.com

# === Apple (for iOS app, optional) ===
# APPLE_BUNDLE_ID=com.example.vpn
# APPLE_TEAM_ID=CHANGE_ME

# === Environment ===
ENVIRONMENT=production
RUST_LOG=info,sqlx=warn
FORCE_HTTPS=0
